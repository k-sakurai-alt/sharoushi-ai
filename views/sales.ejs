<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>営業支援｜シャロAI</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .sales-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px; }
    .agent-card {
      background: white; border-radius: 16px; padding: 28px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      border-top: 4px solid #2e86c1;
    }
    .agent-card h3 { font-size: 1rem; font-weight: 800; margin-bottom: 6px; color: #1a3a5c; }
    .agent-card p { font-size: 0.83rem; color: #7f8c8d; margin-bottom: 16px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
    .form-row input, .agent-card input, .agent-card select {
      width: 100%; padding: 9px 12px; border: 1px solid #dde3ea;
      border-radius: 8px; font-size: 0.88rem; margin-bottom: 8px;
    }
    .btn-agent {
      width: 100%; padding: 11px; background: #1a3a5c; color: white;
      border: none; border-radius: 8px; font-size: 0.9rem; font-weight: 700;
      cursor: pointer; transition: background 0.2s;
    }
    .btn-agent:hover { background: #2e86c1; }
    .result-box {
      display: none; margin-top: 16px;
      background: #f8fafc; border: 1px solid #dde3ea;
      border-radius: 10px; padding: 16px; position: relative;
    }
    .result-box pre {
      white-space: pre-wrap; font-size: 0.85rem; line-height: 1.7;
      color: #2c3e50; font-family: inherit;
    }
    .btn-copy {
      position: absolute; top: 10px; right: 10px;
      background: #2e86c1; color: white; border: none;
      border-radius: 6px; padding: 5px 12px; font-size: 0.78rem;
      cursor: pointer; font-weight: 700;
    }
    .btn-copy:hover { background: #1a6fa8; }
    .loading { color: #7f8c8d; font-size: 0.85rem; text-align: center; padding: 12px; }

    /* ステータスバッジ */
    .badge {
      display: inline-block; padding: 3px 10px; border-radius: 20px;
      font-size: 0.75rem; font-weight: 700;
    }
    .badge-pending  { background: #fef9e7; color: #f39c12; }
    .badge-sent     { background: #eaf4fb; color: #2e86c1; }
    .badge-replied  { background: #e8f8f5; color: #1abc9c; }
    .badge-meeting  { background: #f5eef8; color: #8e44ad; }
    .badge-closed   { background: #eafaf1; color: #27ae60; }
    .badge-rejected { background: #fdedec; color: #e74c3c; }

    /* 進捗テーブル */
    .leads-table { width: 100%; border-collapse: collapse; }
    .leads-table th {
      background: #f0f4f8; text-align: left;
      padding: 10px 12px; font-size: 0.82rem; color: #1a3a5c;
    }
    .leads-table td { padding: 10px 12px; font-size: 0.85rem; border-bottom: 1px solid #f0f0f0; }
    .leads-table tr:hover td { background: #fafbfc; }

    /* 追加フォーム */
    .add-form { display: flex; gap: 8px; flex-wrap: wrap; align-items: flex-end; margin-bottom: 20px; }
    .add-form input { padding: 8px 12px; border: 1px solid #dde3ea; border-radius: 8px; font-size: 0.85rem; }
    .add-form .btn-sm { padding: 8px 18px; background: #1a3a5c; color: white; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 0.85rem; }

    .progress-bar { height: 8px; background: #e5e9ee; border-radius: 4px; margin-bottom: 24px; overflow: hidden; }
    .progress-fill { height: 100%; background: linear-gradient(90deg, #2e86c1, #06c755); border-radius: 4px; transition: width 0.5s; }
    .progress-label { font-size: 0.82rem; color: #7f8c8d; margin-bottom: 6px; }

    @media (max-width: 768px) {
      .sales-grid { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <span class="nav-brand">AIアシスタント管理</span>
    <div class="nav-links">
      <a href="/admin">設定</a>
      <a href="/admin/faqs">FAQ管理</a>
      <a href="/admin/logs">会話ログ</a>
      <a href="/admin/inquiries">問い合わせ</a>
      <a href="/admin/sales" style="font-weight:bold;">営業支援</a>
      <a href="/admin/logout" class="btn-logout">ログアウト</a>
    </div>
  </nav>

  <div class="container">
    <h2>営業支援エージェント</h2>

    <!-- 進捗サマリー -->
    <%
      const total = leads.length;
      const closed = leads.filter(l => l.status === 'closed').length;
      const active = leads.filter(l => ['sent','replied','meeting'].includes(l.status)).length;
      const pct = total > 0 ? Math.round(closed / 20 * 100) : 0;
    %>
    <div class="card" style="margin-bottom:24px;">
      <div style="display:flex; gap:32px; flex-wrap:wrap; margin-bottom:16px;">
        <div><div style="font-size:1.8rem;font-weight:900;color:#1a3a5c;"><%= total %></div><div style="font-size:0.8rem;color:#7f8c8d;">営業先リスト</div></div>
        <div><div style="font-size:1.8rem;font-weight:900;color:#2e86c1;"><%= active %></div><div style="font-size:0.8rem;color:#7f8c8d;">アクティブ商談</div></div>
        <div><div style="font-size:1.8rem;font-weight:900;color:#27ae60;"><%= closed %></div><div style="font-size:0.8rem;color:#7f8c8d;">成約済み</div></div>
        <div><div style="font-size:1.8rem;font-weight:900;color:#f39c12;">¥<%= (closed * 10000).toLocaleString() %></div><div style="font-size:0.8rem;color:#7f8c8d;">月額売上（想定）</div></div>
      </div>
      <div class="progress-label">月20万円達成まで（目標：20社）<%= pct %>%</div>
      <div class="progress-bar"><div class="progress-fill" style="width:<%= pct %>%"></div></div>
    </div>

    <!-- エージェントカード -->
    <div class="sales-grid">

      <!-- 営業メール -->
      <div class="agent-card">
        <h3>📧 営業メールライター</h3>
        <p>事務所名を入れるだけで個別営業メールを自動生成</p>
        <input type="text" id="ce-office" placeholder="事務所名（例：山田社労士事務所）">
        <div class="form-row">
          <input type="text" id="ce-name" placeholder="担当者名（任意）">
          <input type="text" id="ce-pref" placeholder="都道府県（任意）">
        </div>
        <button class="btn-agent" onclick="generate('cold_email','ce')">✨ メールを生成する</button>
        <div class="result-box" id="ce-result">
          <button class="btn-copy" onclick="copyText('ce-text')">コピー</button>
          <pre id="ce-text"></pre>
        </div>
      </div>

      <!-- フォローアップ -->
      <div class="agent-card">
        <h3>🔄 フォローアップライター</h3>
        <p>返信がない時の自然な追いメールを生成</p>
        <input type="text" id="fu-office" placeholder="事務所名">
        <input type="text" id="fu-name" placeholder="担当者名（任意）">
        <button class="btn-agent" onclick="generate('followup','fu')">✨ フォローアップを生成</button>
        <div class="result-box" id="fu-result">
          <button class="btn-copy" onclick="copyText('fu-text')">コピー</button>
          <pre id="fu-text"></pre>
        </div>
      </div>

      <!-- 提案書 -->
      <div class="agent-card">
        <h3>📋 提案書ライター</h3>
        <p>商談後の提案メール本文を生成</p>
        <input type="text" id="pr-office" placeholder="事務所名">
        <div class="form-row">
          <input type="text" id="pr-name" placeholder="担当者名（任意）">
          <input type="text" id="pr-size" placeholder="規模（例：3名）">
        </div>
        <button class="btn-agent" onclick="generate('proposal','pr')">✨ 提案書を生成する</button>
        <div class="result-box" id="pr-result">
          <button class="btn-copy" onclick="copyText('pr-text')">コピー</button>
          <pre id="pr-text"></pre>
        </div>
      </div>

      <!-- 営業先追加 -->
      <div class="agent-card">
        <h3>➕ 営業先を追加</h3>
        <p>新しい営業先をリストに追加する</p>
        <form action="/admin/sales/add" method="POST">
          <input type="text" name="office" placeholder="事務所名 ※必須" required style="margin-bottom:8px;">
          <div class="form-row">
            <input type="text" name="contact_name" placeholder="担当者名">
            <input type="email" name="email" placeholder="メールアドレス">
          </div>
          <input type="text" name="notes" placeholder="メモ（任意）">
          <button type="submit" class="btn-agent" style="margin-top:4px;">リストに追加する</button>
        </form>
      </div>

    </div>

    <!-- 営業進捗リスト -->
    <div class="card">
      <h3 style="margin-bottom:16px;">📊 営業進捗リスト（<%= leads.length %>件）</h3>
      <% if (leads.length === 0) { %>
        <p class="empty">まだ営業先が登録されていません。上のフォームから追加してください。</p>
      <% } else { %>
        <div style="overflow-x:auto;">
          <table class="leads-table">
            <thead>
              <tr>
                <th>事務所名</th>
                <th>担当者</th>
                <th>メール</th>
                <th>ステータス</th>
                <th>メモ</th>
                <th>更新日</th>
                <th>操作</th>
              </tr>
            </thead>
            <tbody>
              <% leads.forEach(lead => { %>
              <tr>
                <td><strong><%= lead.office %></strong></td>
                <td><%= lead.contact_name || '—' %></td>
                <td>
                  <% if (lead.email) { %>
                    <a href="mailto:<%= lead.email %>" style="font-size:0.82rem;"><%= lead.email %></a>
                  <% } else { %>—<% } %>
                </td>
                <td>
                  <% const badges = {pending:'badge-pending',sent:'badge-sent',replied:'badge-replied',meeting:'badge-meeting',closed:'badge-closed',rejected:'badge-rejected'}; %>
                  <% const labels = {pending:'未送信',sent:'送信済',replied:'返信あり',meeting:'商談中',closed:'成約',rejected:'見送り'}; %>
                  <span class="badge <%= badges[lead.status] || 'badge-pending' %>"><%= labels[lead.status] || lead.status %></span>
                </td>
                <td style="max-width:160px;font-size:0.82rem;color:#7f8c8d;"><%= lead.notes || '—' %></td>
                <td style="font-size:0.78rem;color:#aaa;"><%= new Date(lead.updated_at).toLocaleDateString('ja-JP') %></td>
                <td>
                  <form action="/admin/sales/update" method="POST" style="display:inline;">
                    <input type="hidden" name="id" value="<%= lead.id %>">
                    <input type="hidden" name="notes" value="<%= lead.notes || '' %>">
                    <select name="status" onchange="this.form.submit()" style="font-size:0.78rem;padding:3px 6px;border:1px solid #dde3ea;border-radius:6px;">
                      <option value="pending"  <%= lead.status==='pending'  ?'selected':'' %>>未送信</option>
                      <option value="sent"     <%= lead.status==='sent'     ?'selected':'' %>>送信済</option>
                      <option value="replied"  <%= lead.status==='replied'  ?'selected':'' %>>返信あり</option>
                      <option value="meeting"  <%= lead.status==='meeting'  ?'selected':'' %>>商談中</option>
                      <option value="closed"   <%= lead.status==='closed'   ?'selected':'' %>>成約</option>
                      <option value="rejected" <%= lead.status==='rejected' ?'selected':'' %>>見送り</option>
                    </select>
                  </form>
                  <form action="/admin/sales/delete" method="POST" style="display:inline;" onsubmit="return confirm('削除しますか？')">
                    <input type="hidden" name="id" value="<%= lead.id %>">
                    <button type="submit" style="background:none;border:none;color:#e74c3c;cursor:pointer;font-size:0.8rem;margin-left:6px;">削除</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    async function generate(agentType, prefix) {
      const office = document.getElementById(prefix + '-office').value;
      if (!office) { alert('事務所名を入力してください'); return; }

      const btn = event.target;
      btn.textContent = '生成中...';
      btn.disabled = true;

      const body = {
        agent_type: agentType,
        office,
        contact_name: (document.getElementById(prefix + '-name') || {}).value || '',
        prefecture: (document.getElementById(prefix + '-pref') || {}).value || '',
        size: (document.getElementById(prefix + '-size') || {}).value || '',
      };

      try {
        const res = await fetch('/admin/sales/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        const resultBox = document.getElementById(prefix + '-result');
        const textEl = document.getElementById(prefix + '-text');
        if (data.error) {
          textEl.textContent = 'エラー: ' + data.error;
        } else {
          textEl.textContent = data.result;
        }
        resultBox.style.display = 'block';
      } catch(e) {
        alert('通信エラーが発生しました');
      } finally {
        btn.textContent = btn.textContent.includes('メール') ? '✨ メールを生成する' :
                          btn.textContent.includes('フォロー') ? '✨ フォローアップを生成' : '✨ 提案書を生成する';
        btn.disabled = false;
      }
    }

    function copyText(id) {
      const text = document.getElementById(id).textContent;
      navigator.clipboard.writeText(text).then(() => {
        const btn = event.target;
        btn.textContent = '✓ コピー済';
        setTimeout(() => btn.textContent = 'コピー', 1500);
      });
    }
  </script>
</body>
</html>
